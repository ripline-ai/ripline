{
  "name": "@ripline/core",
  "version": "0.1.0",
  "description": "Repeatable AI agent workflows with multi-agent review built in",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ripline-ai/ripline.git"
  },
  "homepage": "https://ripline-ai.github.io/ripline/",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ripline": "bin/ripline.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "pipelines"
  ],
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "demo": "npm run build && node dist/cli/run.js run --demo",
    "demo:area-owner": "npx tsx scripts/run-area-owner-demo.ts",
    "cron:area-owner": "npx tsx scripts/run-area-owner-cron.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:api": "typedoc",
    "docs:build:all": "npm run docs:api && npm run docs:build"
  },
  "keywords": [
    "ripline",
    "pipeline",
    "workflow",
    "agent",
    "multi-agent",
    "review",
    "llm"
  ],
  "author": "Craig Midwinter",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@fastify/cors": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.48",
    "ajv": "^8.18.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fastify": "^5.8.1",
    "json-schema": "^0.4.0",
    "mnemonist": "^0.40.3",
    "uuid": "^11.0.3",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.19.15",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  }
}
